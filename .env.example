# =============================================================================
# Job Research Agent - Environment Configuration
# =============================================================================

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Supported providers: siliconflow, groq, openai

LLM_PROVIDER=siliconflow

# SiliconFlow (OpenAI-compatible) - Primary provider
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# Groq (OpenAI-compatible) - Fallback provider
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# =============================================================================
# Embedding Provider Configuration
# =============================================================================
# Supported providers: siliconflow, openai, local

EMBEDDING_PROVIDER=siliconflow

# SiliconFlow Embedding
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# OpenAI Embedding
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# =============================================================================
# Search Configuration
# =============================================================================
# Optional: Tavily search (free tier: 1000 searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# Qdrant Vector Database
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=job_research

# =============================================================================
# Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8002

# =============================================================================
# Search Configuration
# =============================================================================
MAX_SEARCH_RESULTS=5
SEARCH_TIMEOUT=30
